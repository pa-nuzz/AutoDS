# AutoDS AI Assistant - Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (Primary LLM provider)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Gemini API Key
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Groq API Key (Fast inference)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# DeepSeek API Key
# Get yours at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_key_here

# Backup keys (optional) - for automatic rotation when primary keys fail
# OPENROUTER_API_KEY_2=your_backup_key_2
# OPENROUTER_API_KEY_3=your_backup_key_3
# GEMINI_API_KEY_2=your_backup_key_2
# GROQ_API_KEY_2=your_backup_key_2
# DEEPSEEK_API_KEY_2=your_backup_key_2
